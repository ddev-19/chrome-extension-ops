{
  "manifest_version": 3,
  "name": "DreamPlay User Identifier",
  "version": "1.0.0",
  "description": "Highlights USER IDs on the Ops panel with user type and name",

  "permissions": ["activeTab", "scripting", "storage"],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
